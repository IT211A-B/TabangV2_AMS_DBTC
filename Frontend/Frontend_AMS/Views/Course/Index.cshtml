@{
    @using Frontend_AMS.Models;
    @model IEnumerable<CourseModel>
}
@section Styles {
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
}
@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/jquery/course.js" asp-append-version="true"></script>
}

<!--Header row-->
<div class="page-header">
    <span class="card-title">Course List</span>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
       Add Course
    </button>
</div>

<!--Search row-->
<div class="search-row">
    <input type="text" id="searchInput" placeholder="Search by code or course name..." />
</div>

<!--Table-->
<table id="course-table" class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Course Code</th>
            <th>Course Name</th>
            <th>Assigned Teacher</th>
            <th>Units</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="courseTableBody">
        <tr>
            <td>1</td>
            <td>BSIT</td>
            <td>Bachelor of Science in Information Technology</td>
            <td>John Doe</td>
            <td>4</td>
            <td>
                <button class="btn btn-sm btn-secondary edit-btn" data-id="1">Edit</button>
                <button class="btn btn-sm btn-danger delete-btn" data-id="1">Delete</button>
            </td>
        </tr>
		<!--populated by jQuery -->
    </tbody>
</table>



<!--Create modal-->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input id="createCode" class="form-control mb-2" placeholder="Course Code (e.g. BSIT)" />
                <input id="createName" class="form-control mb-2" placeholder="Course Name" />
                <input id="createTeacher" class="form-control mb-2" placeholder="Assigned Teacher" />
                <input id="createUnits" class="form-control mb-2" placeholder="Units" type="number" min="1" max="9" />
                <p id="createError" class="text-danger small mt-1" style="display:none;"></p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCreateBtn">Save</button>
            </div>

        </div>
    </div>
</div>


<!--Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editId" />
                <input id="editCode" class="form-control mb-2" placeholder="Course Code" />
                <input id="editName" class="form-control mb-2" placeholder="Course Name" />
                <input id="editTeacher" class="form-control mb-2" placeholder="Assigned Teacher" />
                <input id="editUnits" class="form-control mb-2" placeholder="Units" type="number" min="1" max="9" />
                <p id="editError" class="text-danger small mt-1" style="display:none;"></p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="saveEditBtn">Update</button>
            </div>

        </div>
    </div>
</div>

<!--Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Delete Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="deleteId" />
                <p>
                    Are you sure you want to delete
                    <strong id="deleteCourseName" class="text-danger"></strong>?
                </p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>

        </div>
    </div>
</div>
