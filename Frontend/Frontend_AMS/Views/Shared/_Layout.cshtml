<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – EduAttend</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="app">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">
                <div class="logo-mark">
                    <div class="logo-icon">
                        <svg viewBox="0 0 16 16" fill="none" stroke="#fff" stroke-width="2">
                            <path d="M2 4h12M2 8h8M2 12h6" stroke-linecap="round" />
                        </svg>
                    </div>
                    <div>
                        <div class="logo-text">EduAttend</div>
                        <div class="logo-sub">Attendance System</div>
                    </div>
                </div>
            </div>

            <nav>
                <div class="nav-section">Main</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                   href="@Url.Action("Index", "Home")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="1" y="1" width="6" height="6" rx="1" />
                        <rect x="9" y="1" width="6" height="6" rx="1" />
                        <rect x="1" y="9" width="6" height="6" rx="1" />
                        <rect x="9" y="9" width="6" height="6" rx="1" />
                    </svg>
                    Dashboard
                </a>

                <div class="nav-section">Records</div>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Students" ? "active" : "")"
                   href="@Url.Action("Index", "Student")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="8" cy="5" r="3" />
                        <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" />
                    </svg>
                    Students
                </a>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Teachers" ? "active" : "")"
                   href="@Url.Action("Index", "Teacher")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="1" y="9" width="14" height="5" rx="1" />
                        <path d="M4 9V5a4 4 0 018 0v4" />
                    </svg>
                    Teachers
                </a>
                <a class="nav-item @(ViewData["ActivePage"]?.ToString() == "Courses" ? "active" : "")"
                   href="@Url.Action("Index", "Course")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M2 3h12v10H2zM6 3V1M10 3V1M2 7h12" />
                    </svg>
                    Courses
                </a>
            </nav>
        </aside>

        <!-- Main area -->
        <div class="main">
            <div class="topbar">
                <div>
                    <div class="page-title">@ViewData["Title"]</div>
                    <div class="breadcrumb">EduAttend / @ViewData["Title"]</div>
                </div>
                <div class="topbar-right">
                    <div class="avatar">AD</div>
                </div>
            </div>

            <div class="content">
                @RenderBody()
            </div>
        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
