@{

}
<!--Header-->
<div class="card">
	<span class=" card-title">Teacher List</span>
	<button class="btn btn-primary"data-bs-toggle="modal" data-bs-target="#createModal">Add Teacher
	</button>
</div>

<!--Search-->
<div class="search-row">
	<input type="text" class="form-control" placeholder="Search by name or subject">
</div>

<!--Teacher table-->
<table id="teacher-table" class="teacher">
	<thead>
		<tr>
			<th>ID</th>
			<th>Name</th>
			<th>Course</th>
			<th>Status</th>
			<th>Actions</th>
		</tr>
	</thead>
</table>
<tbody>
	<tr>
		<td>1</td>
		<td>John Doe</td>
		<td>Mathematics</td>
		<td>Active</td>
		<td>
			<button class="btn btn-sm btn-warning">Edit</button>
			<button class="btn btn-sm btn-danger">Delete</button>
		</td>
	</tr>
</tbody>

<!--Create Modal-->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Teacher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input id="createName" class="form-control mb-2" placeholder="Full Name" />
                <input id="createCourse" class="form-control mb-2" placeholder="Course" />
                <input id="createEmail" class="form-control mb-2" placeholder="Email" />
                <select id="createStatus" class="form-control mb-2">
                    <option value="">Select Status</option>
                    <option value="Active">Active</option>
                    <option value="On Leave">On Leave</option>
                    <option value="Inactive">Inactive</option>
                </select>
                <p id="createError" class="text-danger small mt-1" style="display:none;"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCreateBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<!--Edit Modal-->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Teacher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editId" />
                <input id="editName" class="form-control mb-2" placeholder="Full Name" />
                <input id="editSubject" class="form-control mb-2" placeholder="Subject / Department" />
                <input id="editEmail" class="form-control mb-2" placeholder="Email" />
                <input id="editPhone" class="form-control mb-2" placeholder="Phone Number" />
                <select id="editStatus" class="form-control mb-2">
                    <option value="">Select Status</option>
                    <option value="Active">Active</option>
                    <option value="On Leave">On Leave</option>
                    <option value="Inactive">Inactive</option>
                </select>
                <p id="editError" class="text-danger small mt-1" style="display:none;"></p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="saveEditBtn">Update</button>
            </div>

        </div>
    </div>
</div>

<!--Delete Modal-->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Delete Teacher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="deleteId" />
                <p>
                    Are you sure you want to delete
                    <strong id="deleteTeacherName" class="text-danger"></strong>?
                </p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>

        </div>
    </div>
</div>
